# Sanity CMS
# Public — embedded in client bundles. These are the project ID and dataset
# name and are safe to expose; they identify which Sanity project to read from.
NEXT_PUBLIC_STORE_SANITY_PROJECT_ID=
NEXT_PUBLIC_STORE_SANITY_DATASET=production

# Server-only Sanity read token (used by the server-side client). Required
# only when reading drafts or private datasets; published content on a public
# dataset works without it.
STORE_SANITY_API_READ_TOKEN=

# Shared secret with the Sanity webhook that pings /api/revalidate. The route
# returns 404 if this is unset, so cache invalidation is disabled.
SANITY_REVALIDATE_SECRET=

# Resend transactional email — used by the contact form server action.
RESEND_API_KEY=
CONTACT_FORM_TO_EMAIL=

# Vercel Cron auth. Vercel attaches `Authorization: Bearer <CRON_SECRET>`
# to every cron invocation when this is set in the project's env; the
# /api/cron/publish-due route 404s on anything else (generate with
# `openssl rand -base64 32`). If unset, the route 404s on every request
# and same-day publishing of future-dated posts is disabled — posts still
# appear within a day via the pages' daily cache revalidation.
CRON_SECRET=

# Public — Google Search Console verification token rendered into <head>.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Rate limiting for the contact form is enforced by Vercel WAF, not by an env
# var here. Create this rule in the Vercel dashboard (Firewall > Rate Limit):
#   - "contact-form"
# If a rule is missing, checkRateLimit() returns error: "not-found" and the
# contact form still works but is unprotected at that layer.
