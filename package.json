{
    "name": "portfolio",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,yml,yaml,css}\"",
        "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,yml,yaml,css}\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "typegen": "sanity schema extract --enforce-required-fields --workspace portfolio-blog && sanity typegen generate",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{js,mjs,json,md,yml,yaml,css}": [
            "prettier --write"
        ]
    },
    "dependencies": {
        "@portabletext/react": "^6.2.0",
        "@portabletext/to-html": "^5.0.2",
        "@radix-ui/react-slot": "^1.3.0",
        "@radix-ui/react-toast": "^1.2.19",
        "@sanity/client": "^7.23.0",
        "@sanity/code-input": "^7.2.5",
        "@sanity/image-url": "^2.1.1",
        "@sanity/vision": "^6.3.0",
        "@vercel/analytics": "^2.0.1",
        "@vercel/firewall": "^1.2.1",
        "@vercel/speed-insights": "^2.0.0",
        "botid": "^1.5.11",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.23.0",
        "next": "^16.2.10",
        "next-sanity": "^13.1.1",
        "next-themes": "^0.4.6",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-email": "^6.6.6",
        "react-icons": "^5.7.0",
        "react-intersection-observer": "^10.0.3",
        "resend": "^6.17.1",
        "sanity": "^6.3.0",
        "server-only": "^0.0.1",
        "shiki": "^4.3.1",
        "tailwind-merge": "^3.6.0",
        "zod": "^4.4.3"
    },
    "pnpm": {
        "overrides": {
            "js-yaml@<3.14.2": "^3.14.2",
            "js-yaml@>=4.0.0 <=4.1.1": "^4.2.0",
            "postcss@<8.5.10": "^8.5.10",
            "uuid@<11.1.1": "^11.1.1",
            "uuid@>=13.0.0 <13.0.1": "^13.0.1",
            "tsx>esbuild": "^0.28.1",
            "vite>esbuild": "^0.28.1",
            "form-data@>=4.0.0 <4.0.6": "^4.0.6",
            "vite@>=7.0.0 <=7.3.4": "^7.3.5",
            "undici@>=7.0.0 <7.28.0": "^7.28.0",
            "tar@<=7.5.15": "^7.5.16",
            "dompurify@<3.4.11": "^3.4.11",
            "@babel/core@<=7.29.0": "^7.29.6",
            "smol-toml@<1.6.1": "^1.6.1",
            "@actions/http-client>undici": "^6.27.0",
            "@actions/github>undici": "^6.27.0"
        }
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.3.2",
        "@types/node": "^26.1.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitest/coverage-v8": "^4.1.9",
        "eslint": "^9.39.4",
        "eslint-config-next": "^16.2.10",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "postcss": "^8.5.16",
        "prettier": "^3.9.4",
        "tailwindcss": "^4.3.2",
        "typescript": "~6.0.3",
        "vitest": "^4.1.9"
    }
}
